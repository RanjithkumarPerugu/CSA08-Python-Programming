r = int(input("Enter number of rows: "))
c = int(input("Enter number of columns: "))

A = []
B = []

print("Enter Matrix A:")
for i in range(r):
    row = []
    for j in range(c):
        row.append(int(input()))
    A.append(row)

print("Enter Matrix B:")
for i in range(r):
    row = []
    for j in range(c):
        row.append(int(input()))
    B.append(row)

print("Matrix Addition:")
for i in range(r):
    for j in range(c):
        print(A[i][j] + B[i][j], end=" ")
    print()
