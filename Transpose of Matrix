r = int(input("Enter rows: "))
c = int(input("Enter columns: "))

matrix = []

print("Enter matrix:")
for i in range(r):
    row = []
    for j in range(c):
        row.append(int(input()))
    matrix.append(row)

print("Transpose Matrix:")
for i in range(c):
    for j in range(r):
        print(matrix[j][i], end=" ")
    print()
